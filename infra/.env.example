# Copy to repo-root .env and fill in.  NEVER commit the real .env.
# Generate a session secret:  python -c "import secrets; print(secrets.token_urlsafe(48))"

QP_ENV=dev
QP_SESSION_SECRET=change-me-generate-a-strong-value
QP_CORS_ORIGINS=http://localhost:3000
QP_TRADING_ENABLED=false

# --- Postgres (docker-compose) ---
POSTGRES_USER=quant
POSTGRES_PASSWORD=change-me
POSTGRES_DB=quant_pilot

# --- Local (non-docker) connection strings ---
QP_DATABASE_URL=postgresql+psycopg://quant:change-me@localhost:5432/quant_pilot
QP_REDIS_URL=redis://localhost:6379/0

# Broker API keys are NOT stored here. They live in the OS keychain (SYSTEM_DESIGN §8.3),
# accessed via the SecretStore adapter. Plaintext secrets never touch the repo or DB.
